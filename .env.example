# UnifyCOI — environment contract. Copy to `.env`, fill real values, never commit `.env`.
# !! NEVER put real values here — this file IS committed to git !!
# Placeholder values below; replace everything in <angle brackets>.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<long-random-string>
JWT_EXPIRES_IN=12h
ONBOARDING_TOKEN_TTL_DAYS=14
# Login throttle (SEC-9). Rolling window; soft lockout derived from windowed failure counts.
LOGIN_MAX_PER_EMAIL=5
LOGIN_MAX_PER_IP=30
LOGIN_RATE_WINDOW_SECONDS=900

# ── Database (SQLite / better-sqlite3) ────────────────────────────────────────
SQLITE_PATH=./data/unifycoi.db

# ── Anthropic / Claude Vision ─────────────────────────────────────────────────
# Console API key with its OWN usage billing — separate from your Max subscription.
ANTHROPIC_API_KEY=<sk-ant-...>
VISION_MODEL_PRIMARY=claude-sonnet-4-6
VISION_MODEL_ESCALATION=claude-opus-4-8
EXTRACTION_SCHEMA_VERSION=1

# ── Object storage: Backblaze B2 (S3-compatible), behind BlobStore ────────────
# Same driver dev + prod — SEPARATE buckets + scoped keys per environment.
STORAGE_DRIVER=s3
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
S3_BUCKET=unifycoi-documents-dev
S3_ACCESS_KEY_ID=<b2-application-key-id>
S3_SECRET_ACCESS_KEY=<b2-application-key>
S3_FORCE_PATH_STYLE=false
FILESYSTEM_STORAGE_DIR=./data/blobs

# ── Encryption (keys live OUTSIDE the DB and the bucket) ──────────────────────
MASTER_KEK=<base64-32-byte-key>
FIELD_ENCRYPTION_KEY=<base64-32-byte-key>

# ── Email / notifications (Resend ESP) ────────────────────────────────────────
# Leave RESEND_API_KEY empty to fall back to the logged NoOp mailer (dev/test/CI).
RESEND_API_KEY=<re_...>
# Shared verified sending domain. Operator name rides in the From display name
# (per-operator DKIM domains are deferred — FEAT-13).
MAIL_FROM_EMAIL=noreply@unifycoi-mail.com
# Svix signing secret for the /api/webhooks/resend delivery webhook. Empty → the
# webhook rejects every event (fail-closed).
RESEND_WEBHOOK_SECRET=<whsec_...>
DIGEST_HOUR_LOCAL=8

# ── Tunable config defaults ───────────────────────────────────────────────────
CONF_BAND_HIGH=0.90
CONF_BAND_MED=0.75
RETENTION_YEARS=7
RENEWAL_CHASE_LADDER=60,30,14,7,1
