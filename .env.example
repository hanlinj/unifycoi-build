# ─── Database ────────────────────────────────────────────────────────────────
SQLITE_PATH=./data/unifycoi.db

# ─── Storage ──────────────────────────────────────────────────────────────────
# 's3' for dev/prod (Backblaze B2); 'filesystem' is used only by tests/CI
STORAGE_DRIVER=s3

# Backblaze B2 S3-compatible settings (dev bucket — use separate bucket/key per env)
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
S3_BUCKET=unifycoi-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Filesystem adapter base path (tests/CI only; ignored when STORAGE_DRIVER=s3)
STORAGE_PATH=./data/blobs

# ─── Encryption ───────────────────────────────────────────────────────────────
# Master Key Encryption Key — wraps per-object data keys (envelope encryption)
# Generate: openssl rand -hex 32
MASTER_KEK=

# Field-level encryption key — encrypts Sensitive DB fields (TIN, ACH account/routing)
# Generate: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# HMAC secret for JWT signing (HS256)
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=8h
