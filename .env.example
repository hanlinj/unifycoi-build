# UnifyCOI — environment contract. Copy to `.env`, fill real values, never commit `.env`.
# !! NEVER put real values here — this file IS committed to git !!
# Placeholder values below; replace everything in <angle brackets>.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
# CSRF Origin allow-list (SEC-12) — comma-separated exact origins, used only when a request
# omits Sec-Fetch-Site (modern browsers send it, so this is the fallback path). Unset →
# defaults to APP_BASE_URL's origin + http://localhost:3000. Add your Tailscale/LAN origin
# here if you hit the dev box from a non-Sec-Fetch-Site client (e.g. curl, older browser):
# ALLOWED_ORIGINS=http://localhost:3000,https://your-box.tailnet-xxxx.ts.net

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<long-random-string>
JWT_EXPIRES_IN=12h
ONBOARDING_TOKEN_TTL_DAYS=14
# Login throttle (SEC-9). Rolling window; soft lockout derived from windowed failure counts.
LOGIN_MAX_PER_EMAIL=5
LOGIN_MAX_PER_IP=30
LOGIN_RATE_WINDOW_SECONDS=900

# ── Database (SQLite / better-sqlite3) ────────────────────────────────────────
SQLITE_PATH=./data/unifycoi.db

# ── Anthropic / Claude Vision ─────────────────────────────────────────────────
# Console API key with its OWN usage billing — separate from your Max subscription.
ANTHROPIC_API_KEY=<sk-ant-...>
VISION_MODEL_PRIMARY=claude-sonnet-4-6
VISION_MODEL_ESCALATION=claude-opus-4-8
EXTRACTION_SCHEMA_VERSION=1

# ── Object storage: Backblaze B2 (S3-compatible), behind BlobStore ────────────
# Same driver dev + prod — SEPARATE buckets + scoped keys per environment.
STORAGE_DRIVER=s3
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
S3_BUCKET=unifycoi-documents-dev
S3_ACCESS_KEY_ID=<b2-application-key-id>
S3_SECRET_ACCESS_KEY=<b2-application-key>
S3_FORCE_PATH_STYLE=false
FILESYSTEM_STORAGE_DIR=./data/blobs

# ── Encryption (keys live OUTSIDE the DB and the bucket) ──────────────────────
MASTER_KEK=<base64-32-byte-key>
FIELD_ENCRYPTION_KEY=<base64-32-byte-key>

# ── Observability (OPS-12) ────────────────────────────────────────────────────
# Empty SENTRY_DSN → error capture is a pino-only no-op (dev/test/CI). beforeSend
# scrubs all Sensitive values before any event leaves the process.
SENTRY_DSN=
LOG_LEVEL=info

# ── Secrets management (OPS-13) — Doppler ─────────────────────────────────────
# All secrets above (KEKs, JWT_SECRET, B2 creds, RESEND_*, SENTRY_DSN) are injected by
# Doppler at deploy; env.ts stays the single chokepoint that reads them. On a SINGLE host
# this buys encrypted-at-rest storage + central rotation/audit of secret values — it does
# NOT provide runtime process isolation (a compromised app process still sees its own env).
#
# BUILD-TIME FOOTGUN: Next inlines process.env references used in EDGE middleware at BUILD
# time, not runtime. ALLOWED_ORIGINS (and any other edge-middleware env) MUST be present in
# the BUILD environment (`doppler run -- next build`), not only injected at runtime — else
# the edge bundle inlines `undefined` and every Origin-fallback mutation 403s. Runtime-only
# values (DB, B2, Resend, Sentry, KEKs — all read in the Node runtime) can be injected at
# start (`doppler run -- next start`). Keep the two sets distinct in the deploy pipeline.

# ── Email / notifications (Resend ESP) ────────────────────────────────────────
# Leave RESEND_API_KEY empty to fall back to the logged NoOp mailer (dev/test/CI).
RESEND_API_KEY=<re_...>
# Shared verified sending domain. Operator name rides in the From display name
# (per-operator DKIM domains are deferred — FEAT-13).
MAIL_FROM_EMAIL=noreply@unifycoi-mail.com
# Svix signing secret for the /api/webhooks/resend delivery webhook. Empty → the
# webhook rejects every event (fail-closed).
RESEND_WEBHOOK_SECRET=<whsec_...>
DIGEST_HOUR_LOCAL=8

# ── Billing (Stripe, OPS-10 — owner-approved spec deviation; ADR-012-03/05) ────
# Leave STRIPE_SECRET_KEY empty to fall back to the NoOp billing provider (dev/test/CI):
# provisioning still attaches a synthetic customer/subscription so the flow works offline.
STRIPE_SECRET_KEY=<sk_test_...>
# Publishable key — for the (not yet built) hosted card-entry step; safe to expose client-side.
STRIPE_PUBLISHABLE_KEY=<pk_test_...>
# Signing secret for POST /api/webhooks/stripe (invoice.paid → tenant activation + Admin
# invite). Empty → the webhook fails closed (503), same fail-closed posture as Resend's.
# For local dev, `stripe listen --forward-to localhost:3000/api/webhooks/stripe` prints one.
STRIPE_WEBHOOK_SECRET=<whsec_...>
# Poll cadence for the billing quantity-sync worker (pushes location-count changes to the
# Stripe subscription quantity, next cycle only). Not time-sensitive — default is 5 minutes.
BILLING_SYNC_WORKER_POLL_SECONDS=300

# ── Tunable config defaults ───────────────────────────────────────────────────
CONF_BAND_HIGH=0.90
CONF_BAND_MED=0.75
RETENTION_YEARS=7
RENEWAL_CHASE_LADDER=60,30,14,7,1
