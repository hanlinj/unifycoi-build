# Secrets — ignore the real env, KEEP the example
.env
.env.local
.env.*.local
!.env.example

# Node / Next.js
node_modules/
.next/
out/
dist/
build/

# Generated at postinstall (scripts/copy-pdf-worker.js) — regenerated from node_modules,
# never committed, same treatment as node_modules itself.
/public/pdf.worker.min.mjs

# Local data (SQLite db + filesystem-adapter blobs — never commit vendor data)
data/
*.db
*.sqlite
*.sqlite3

# OS / editor
.DS_Store
*.log
.vscode/
.idea/

# Session/harness tooling — not product
.agents/
.claude/
skills-lock.json
